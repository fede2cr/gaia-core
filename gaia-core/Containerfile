# syntax=docker/dockerfile:1

# ── Stage 1: Build ────────────────────────────────────────────────────────
FROM docker.io/library/rust:1-trixie AS builder

ARG TARGETARCH

# Install wasm target + cargo-leptos.
# Cache mounts keep the cargo registry and cargo-leptos binary across builds
# so this layer is essentially free after the first run.
RUN --mount=type=cache,id=cargo-reg-${TARGETARCH},target=/usr/local/cargo/registry \
    --mount=type=cache,id=cargo-git-${TARGETARCH},target=/usr/local/cargo/git \
    rustup target add wasm32-unknown-unknown \
    && cargo install cargo-leptos

WORKDIR /build
COPY . .

# Build SSR binary + WASM client bundle.
# Cache mounts persist compiled dependencies across source changes so only
# modified crates are recompiled (incremental compilation).
# Artifacts are copied to /tmp because cache mounts are not part of the image layer.
#
# wasm-bindgen-cli is installed from source (matching the exact version in
# Cargo.lock) so cargo-leptos never needs to download a prebuilt binary.
# This is required for arm64 where no prebuilt binaries are published.
ENV LEPTOS_WASM_OPT_VERSION=version_127
RUN --mount=type=cache,id=cargo-reg-${TARGETARCH},target=/usr/local/cargo/registry \
    --mount=type=cache,id=cargo-git-${TARGETARCH},target=/usr/local/cargo/git \
    --mount=type=cache,id=target-${TARGETARCH},target=/build/target \
    WB_VERSION=$(grep -A1 'name = "wasm-bindgen"' Cargo.lock | grep version | head -1 | sed 's/.*"\(.*\)"/\1/') \
    && cargo install wasm-bindgen-cli --version "$WB_VERSION" \
    && cargo leptos build --release \
    && cp target/release/gaia-core /tmp/gaia-core \
    && cp -r target/site /tmp/site

# ── Stage 2: Runtime ──────────────────────────────────────────────────────
FROM docker.io/library/debian:trixie-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates \
        alsa-utils \
        avahi-daemon \
        avahi-utils \
        dbus \
        podman-remote \
        tini \
        bash \
    && rm -rf /var/lib/apt/lists/* \
    && sed -i 's/^rlimit-nproc=.*/#&/' /etc/avahi/avahi-daemon.conf \
    && ln -sf /usr/bin/podman-remote /usr/local/bin/podman

WORKDIR /app

# Copy the server binary
COPY --from=builder /tmp/gaia-core /app/gaia-core

# Copy the compiled site (WASM bundle, CSS, static assets)
COPY --from=builder /tmp/site /app/site

# Copy the entrypoint script that starts dbus + avahi before the server
COPY entrypoint.sh /app/entrypoint.sh
RUN chmod +x /app/entrypoint.sh

# Persistent data directory for assignments
RUN mkdir -p /app/data

# Leptos needs to know where the site root is at runtime
ENV LEPTOS_SITE_ROOT=/app/site
ENV LEPTOS_SITE_ADDR=0.0.0.0:3100
ENV LEPTOS_OUTPUT_NAME=gaia-core
ENV LEPTOS_SITE_PKG_DIR=pkg
ENV GAIA_CONFIG_DIR=/app/data
ENV CONTAINER_HOST=unix:///run/podman/podman.sock
ENV CONTAINER_RUNTIME=podman

EXPOSE 3100

ENTRYPOINT ["tini", "--", "/app/entrypoint.sh"]
